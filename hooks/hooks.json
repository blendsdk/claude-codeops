{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/standards/coding-standards.md\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'input=$(cat); case \"$input\" in *\"codeops/.codeops.yml\"*) echo \"WARN: codeops/.codeops.yml is the layout marker, owned by the setup_codeops skill - editing it directly risks breaking layout detection (see _shared/layout-convention.md).\" >&2 ;; esac; exit 0'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill|Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/codeops-events.sh\" emit --src hook --stdin"
          }
        ]
      }
    ]
  }
}
